---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { AboutProps, HeroProps } from "@types";

type Props = AboutProps & Pick<HeroProps, "name">;

const { description, image, name } = Astro.props;
---

<Section text="About Me" href="about">
  <div class="relative flex flex-col items-start gap-12 lg:flex-row lg:gap-20">
    <div class="space-y-6 lg:w-2/3">
      <div class="prose prose-invert max-w-none">
        <p class="text-lg leading-relaxed text-neutral/90 italic">
          {description.split('\n\n')[0]}
        </p>
        <div class="h-px w-20 bg-primary/30 my-8"></div>
        <p class="text-base leading-relaxed text-neutral/80">
          {description.split('\n\n')[1]}
        </p>
      </div>
      
      <div class="flex items-center gap-4 pt-6">
        <div class="h-10 w-10 rounded-full border border-primary/30 bg-primary/10 flex items-center justify-center font-mono text-xs font-bold text-primary">
          ML
        </div>
        <div>
          <p class="text-sm font-bold text-white uppercase tracking-tighter">{name}</p>
          <p class="text-xs text-neutral font-mono uppercase tracking-widest leading-none">Engineer & Gamer</p>
        </div>
      </div>
    </div>

    <div class="relative lg:w-1/3">
      <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/5">
        <Image
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          src={image}
          width="400"
          height="400"
          alt={name}
        />
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 via-transparent to-transparent opacity-0 transition-opacity group-hover:opacity-100" />
      </div>
      <div class="absolute -bottom-4 -left-4 -z-10 h-24 w-24 rounded-full bg-primary/10 blur-2xl" />
      <div class="absolute -right-4 -top-4 -z-10 h-32 w-32 rounded-full bg-indigo-500/10 blur-3xl" />
    </div>
  </div>
</Section>
