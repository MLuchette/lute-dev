---
import Layout from "../layouts/Layout.astro";
import { FluidBackground } from "../projects/react-fluid";

// Immersive mode: we replace the standard main content but keep the layout metadata
---

<Layout showHeader={false} showFooter={false}>
  <!-- Background Layer -->
  <div class="fixed inset-0 -z-10 bg-[#010410]" />
  
  <!-- UI Layer -->
  <div class="fixed inset-0 z-50 flex flex-col items-center justify-center pointer-events-none">
    <div class="pointer-events-auto flex flex-col items-center gap-6">
      <h1 class="font-serif text-5xl font-bold tracking-tight text-white md:text-7xl">
        Liquid Canvas
      </h1>
      <p class="font-mono text-xs text-primary uppercase tracking-widest bg-primary/10 px-4 py-2 rounded-full border border-primary/20">
        Swipe or hover to interact
      </p>
      <a 
        href="/" 
        class="mt-12 inline-block rounded-full border border-white/20 bg-white/5 px-8 py-4 text-sm font-bold text-white transition-all hover:bg-white/10"
      >
        ← Back to Portfolio
      </a>
    </div>
  </div>

  <!-- Fluid Simulation (Client side only) -->
  <FluidBackground client:only="react" />
</Layout>

<style is:global>
  /* Ensure the fluid canvas fills the screen properly */
  #fluid-canvas {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    pointer-events: none !important;
    z-index: 10 !important;
    opacity: 0.8 !important;
  }
</style>
